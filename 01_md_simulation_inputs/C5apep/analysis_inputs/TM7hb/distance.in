distance 261-265_1 :261@OD1 :265@ND2 out dist-261-265_1.dat #
distance 261-265_2 :261@OD1 :265@OD1 out dist-261-265_2.dat #
distance 261-265_3 :261@ND2 :265@OD1 out dist-261-265_3.dat #
distance 261-265_4 :261@ND2 :265@ND2 out dist-261-265_4.dat #
run
