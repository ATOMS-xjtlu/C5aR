parm ../input.parm7 #top
trajin ../production.trj # md3.trj 1 12500 1)112500
trajin ../production1.trj
trajin ../production2.trj
#trajin ../production_third_4.trj
#countframes #
#reference complex-amber.pdb
#fiximagedbonds
autoimage #pbc
rms first @CA #fitfitreference
#center :340  mass origin #pbc
